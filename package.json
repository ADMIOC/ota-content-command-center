    "preview:social": "NODE_ENV=production node server/index.mjs",
    "check": "node --check server.js && vite build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.2",
    "express": "^4.18.3",
    "image-size": "^2.0.2",
    "multer": "^1.4.5-lts.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
