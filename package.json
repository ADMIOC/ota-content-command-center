{
  "name": "ota-content-command-center",
  "version": "0.2.0",
  "private": true,
  "description": "OTA Social Engine Content Command Center MVP with local backend and Social Engine app shells.",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "dev:social": "node server/local.mjs",
